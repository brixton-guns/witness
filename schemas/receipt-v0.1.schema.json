{
  "$id": "https://witness.invalid/schemas/receipt-v0.1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "receipt_version": {
      "const": "witness.receipt/0.1"
    },
    "signature": {
      "additionalProperties": false,
      "properties": {
        "algorithm": {
          "const": "ed25519"
        },
        "value": {
          "pattern": "^[A-Za-z0-9_-]{86}$",
          "type": "string"
        }
      },
      "required": [
        "algorithm",
        "value"
      ],
      "type": "object"
    },
    "signed": {
      "additionalProperties": false,
      "properties": {
        "authority": {
          "additionalProperties": false,
          "properties": {
            "id": {
              "maxLength": 128,
              "minLength": 1,
              "pattern": "^[a-z0-9][a-z0-9.-]*$",
              "type": "string"
            },
            "key_id": {
              "pattern": "^ed25519:[0-9a-f]{64}$",
              "type": "string"
            }
          },
          "required": [
            "id",
            "key_id"
          ],
          "type": "object"
        },
        "log_index": {
          "maximum": 9007199254740991,
          "minimum": 1,
          "type": "integer"
        },
        "receipt_id": {
          "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$",
          "type": "string"
        },
        "received_at": {
          "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])-([0-2][0-9]|3[01])T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]Z$",
          "type": "string"
        },
        "statement": {
          "$ref": "statement-v0.1.schema.json"
        }
      },
      "required": [
        "authority",
        "log_index",
        "receipt_id",
        "received_at",
        "statement"
      ],
      "type": "object"
    }
  },
  "required": [
    "receipt_version",
    "signature",
    "signed"
  ],
  "title": "Witness receipt v0.1",
  "type": "object"
}
